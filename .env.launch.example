# ARCHON Launch Post Automation — API Keys
# Copy this file to .env and fill in your credentials

# ─── X (TWITTER) ─────────────────────────────────────────────────────────────
# Get from: https://developer.twitter.com/en/portal/dashboard
# Required plan: Free tier is READ ONLY. You need Basic ($100/mo) to post.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ─── LINKEDIN ─────────────────────────────────────────────────────────────────
# Get from: https://www.linkedin.com/developers/apps
# Steps:
#   1. Create an app → Request "Share on LinkedIn" + "Sign In with LinkedIn" products
#   2. Generate an access token via OAuth 2.0 (w_member_social scope)
LINKEDIN_ACCESS_TOKEN=

# ─── CURSOR FORUM (DISCOURSE) ─────────────────────────────────────────────────
# Get from: https://forum.cursor.com/admin/api/keys  (requires admin/moderator)
# OR: Your user preferences → API → Generate Personal API Key
CURSOR_FORUM_URL=https://forum.cursor.com
CURSOR_FORUM_API_KEY=
CURSOR_FORUM_USERNAME=
